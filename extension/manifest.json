{
  "manifest_version": 3,
  "name": "AI Product Insights",
  "version": "1.0.0",
  "description": "AI-powered insights for Open Food Facts products",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.openfoodfacts.org/product/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.openfoodfacts.org/product/*"
      ],
      "js": ["content/content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Product Insights"
  }
}
