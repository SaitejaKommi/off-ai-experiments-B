# LLM API Configuration
# Copy this file to .env and add your actual API keys

# Google Gemini API Key
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative: Groq API Key (if using Groq instead)
# Get yours from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LLM Provider to use: "gemini" or "groq"
LLM_PROVIDER=groq

# Model selection
GEMINI_MODEL=models/gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Feature flags
USE_LLM_PAIRINGS=true
LLM_FALLBACK_TO_RULES=false
